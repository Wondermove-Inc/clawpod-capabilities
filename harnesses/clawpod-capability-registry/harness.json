{
  "schemaVersion": 1,
  "kind": "openclaw.harness.v1",
  "name": "clawpod-capability-registry",
  "title": "ClawPod Capability Registry",
  "description": "Search, assess, install, validate, update, and roll back capabilities, with deterministic registry-first WORKFLOW onboarding.",
  "version": "0.3.1",
  "entrypoint": "./clawpod_capability_registry.py",
  "packageRoot": ".",
  "whenToUse": [
    "An agent needs to discover reusable capabilities",
    "A capability must be installed with provenance and digest checks",
    "An installed capability needs validation, update, or rollback",
    "Registry-first creation policy must be activated or checked in an agent-owned WORKFLOW.md"
  ],
  "capabilities": [
    "registry-search",
    "verified-install",
    "local-validation",
    "backup",
    "rollback",
    "workflow-policy-status",
    "workflow-policy-onboarding"
  ],
  "authModel": {
    "type": "public-read",
    "storesSecrets": false,
    "requiresHumanAccount": false
  },
  "commands": {
    "list": {
      "description": "List capabilities in the canonical registry.",
      "baseArgv": [
        "list"
      ],
      "safetyClasses": [
        "readOnly"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": []
    },
    "search": {
      "description": "Search capability ids and descriptions.",
      "baseArgv": [
        "search"
      ],
      "safetyClasses": [
        "readOnly"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": [
        {
          "arg": "query",
          "type": "option",
          "flag": "--query",
          "valueType": "string"
        },
        {
          "arg": "limit",
          "type": "option",
          "flag": "--limit",
          "valueType": "integer",
          "optional": true
        }
      ]
    },
    "inspect": {
      "description": "Inspect one capability and its compatibility and safety metadata.",
      "baseArgv": [
        "inspect"
      ],
      "safetyClasses": [
        "readOnly"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": [
        {
          "arg": "id",
          "type": "option",
          "flag": "--id",
          "valueType": "string"
        },
        {
          "arg": "version",
          "type": "option",
          "flag": "--version",
          "valueType": "string",
          "optional": true
        },
        {
          "arg": "type",
          "type": "option",
          "flag": "--type",
          "valueType": "string",
          "optional": true
        }
      ]
    },
    "install": {
      "description": "Install a capability into an explicit local target root after digest verification. For clawpod-capability-registry itself, workflowPath is required and onboarding completes transactionally.",
      "baseArgv": [
        "install"
      ],
      "safetyClasses": [
        "writeSafe"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "targetRoot": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "skillsRoot": {
            "type": "string"
          },
          "harnessesRoot": {
            "type": "string"
          },
          "workflowPath": {
            "type": "string"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": [
        {
          "arg": "id",
          "type": "option",
          "flag": "--id",
          "valueType": "string"
        },
        {
          "arg": "version",
          "type": "option",
          "flag": "--version",
          "valueType": "string",
          "optional": true
        },
        {
          "arg": "type",
          "type": "option",
          "flag": "--type",
          "valueType": "string",
          "optional": false
        },
        {
          "arg": "targetRoot",
          "type": "option",
          "flag": "--target-root",
          "valueType": "path",
          "pathRole": "inout",
          "optional": true
        },
        {
          "arg": "skillsRoot",
          "type": "option",
          "flag": "--skills-root",
          "valueType": "path",
          "pathRole": "inout",
          "optional": true
        },
        {
          "arg": "harnessesRoot",
          "type": "option",
          "flag": "--harnesses-root",
          "valueType": "path",
          "pathRole": "inout",
          "optional": true
        },
        {
          "arg": "workflowPath",
          "type": "option",
          "flag": "--workflow-path",
          "valueType": "path",
          "pathRole": "inout",
          "optional": true
        }
      ]
    },
    "validate": {
      "description": "Validate installed files against the canonical registry digests.",
      "baseArgv": [
        "validate"
      ],
      "safetyClasses": [
        "readOnly"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "targetRoot": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "skillsRoot": {
            "type": "string"
          },
          "harnessesRoot": {
            "type": "string"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": [
        {
          "arg": "id",
          "type": "option",
          "flag": "--id",
          "valueType": "string"
        },
        {
          "arg": "version",
          "type": "option",
          "flag": "--version",
          "valueType": "string",
          "optional": true
        },
        {
          "arg": "type",
          "type": "option",
          "flag": "--type",
          "valueType": "string",
          "optional": false
        },
        {
          "arg": "targetRoot",
          "type": "option",
          "flag": "--target-root",
          "valueType": "path",
          "pathRole": "input",
          "optional": true
        },
        {
          "arg": "skillsRoot",
          "type": "option",
          "flag": "--skills-root",
          "valueType": "path",
          "pathRole": "input",
          "optional": true
        },
        {
          "arg": "harnessesRoot",
          "type": "option",
          "flag": "--harnesses-root",
          "valueType": "path",
          "pathRole": "input",
          "optional": true
        }
      ]
    },
    "update": {
      "description": "Update an installed capability after creating a local rollback backup. For clawpod-capability-registry itself, workflowPath is required and onboarding completes transactionally.",
      "baseArgv": [
        "update"
      ],
      "safetyClasses": [
        "writeSafe"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "targetRoot": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "skillsRoot": {
            "type": "string"
          },
          "harnessesRoot": {
            "type": "string"
          },
          "workflowPath": {
            "type": "string"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": [
        {
          "arg": "id",
          "type": "option",
          "flag": "--id",
          "valueType": "string"
        },
        {
          "arg": "version",
          "type": "option",
          "flag": "--version",
          "valueType": "string",
          "optional": true
        },
        {
          "arg": "type",
          "type": "option",
          "flag": "--type",
          "valueType": "string",
          "optional": false
        },
        {
          "arg": "targetRoot",
          "type": "option",
          "flag": "--target-root",
          "valueType": "path",
          "pathRole": "inout",
          "optional": true
        },
        {
          "arg": "skillsRoot",
          "type": "option",
          "flag": "--skills-root",
          "valueType": "path",
          "pathRole": "inout",
          "optional": true
        },
        {
          "arg": "harnessesRoot",
          "type": "option",
          "flag": "--harnesses-root",
          "valueType": "path",
          "pathRole": "inout",
          "optional": true
        },
        {
          "arg": "workflowPath",
          "type": "option",
          "flag": "--workflow-path",
          "valueType": "path",
          "pathRole": "inout",
          "optional": true
        }
      ]
    },
    "rollback": {
      "description": "Restore the latest or selected local capability backup.",
      "baseArgv": [
        "rollback"
      ],
      "safetyClasses": [
        "writeSafe"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "targetRoot"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "targetRoot": {
            "type": "string"
          },
          "backup": {
            "type": "string"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": [
        {
          "arg": "id",
          "type": "option",
          "flag": "--id",
          "valueType": "string"
        },
        {
          "arg": "targetRoot",
          "type": "option",
          "flag": "--target-root",
          "valueType": "path",
          "pathRole": "inout"
        },
        {
          "arg": "backup",
          "type": "option",
          "flag": "--backup",
          "valueType": "path",
          "pathRole": "input",
          "optional": true
        }
      ]
    },
    "workflow-status": {
      "description": "Read the versioned registry-first managed policy status without modifying WORKFLOW.md.",
      "baseArgv": [
        "workflow-status"
      ],
      "safetyClasses": [
        "readOnly"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workflowPath"
        ],
        "properties": {
          "workflowPath": {
            "type": "string"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": [
        {
          "arg": "workflowPath",
          "type": "option",
          "flag": "--workflow-path",
          "valueType": "path",
          "pathRole": "input"
        }
      ]
    },
    "workflow-activate": {
      "description": "Atomically append or replace only the exact registry-first managed block in an existing WORKFLOW.md.",
      "baseArgv": [
        "workflow-activate"
      ],
      "safetyClasses": [
        "writeSafe"
      ],
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "workflowPath"
        ],
        "properties": {
          "workflowPath": {
            "type": "string"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": [
          "ok",
          "command",
          "data"
        ]
      },
      "argMap": [
        {
          "arg": "workflowPath",
          "type": "option",
          "flag": "--workflow-path",
          "valueType": "path",
          "pathRole": "inout"
        }
      ]
    }
  },
  "execution": {
    "cwd": ".",
    "timeoutMs": 30000,
    "requiresJson": true
  }
}
